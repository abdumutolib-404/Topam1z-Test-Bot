# ════════════════════════════════════════════════════════════════════════
#  @topam1z_bot — environment variables
#  Copy to .env and fill in — NEVER commit .env to git
# ════════════════════════════════════════════════════════════════════════

# ── Telegram Bot ──────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here

# ── Telegram Local API Server (from my.telegram.org) ─────────────────
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# ── Bot admin ─────────────────────────────────────────────────────────
ADMIN_IDS=7200560574
ADMIN_PASS=your_admin_password

# ── Neon PostgreSQL ───────────────────────────────────────────────────
# Get from: console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Optional ──────────────────────────────────────────────────────────
SHAZAM_KEY=

# NOTE: Do NOT put cookies here. Put them in cookies.txt instead.
# See setup instructions below.
